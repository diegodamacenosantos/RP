        "field": "payload",
        "fieldType": "msg",
        "format": "html",
        "syntax": "mustache",
        "template": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n\n<link href=\"https://cdn.jsdelivr.net/npm/@mdi/font/css/materialdesignicons.min.css\" rel=\"stylesheet\">\n\n<style>\n\nbody{\n    margin:0;\n    height:100vh;\n    display:flex;\n    justify-content:center;\n    align-items:center;\n    background:#111;\n    font-family:Segoe UI, sans-serif;\n}\n\n.smart-room{\n    width:85px;\n    height:85px;\n    border-radius:14px;\n    padding:6px;\n    cursor:pointer;\n\n    display:flex;\n    flex-direction:column;\n    justify-content:space-between;\n\n    background:linear-gradient(145deg,#2c2c2c,#1a1a1a);\n    border:2px solid #404040;\n    color:white;\n\n    transition:.25s;\n    position:relative;\n    overflow:hidden;\n}\n\n.smart-room:hover{\n    transform:translateY(-2px);\n}\n\n.smart-room.active{\n    background:linear-gradient(145deg,#2e5c2e,#1a3d1a);\n    border-color:#4CAF50;\n    box-shadow:0 0 12px rgba(76,175,80,.4);\n}\n\n.header{\n    display:flex;\n    justify-content:space-between;\n    font-size:10px;\n}\n\n.dot{\n    width:6px;\n    height:6px;\n    border-radius:50%;\n    background:#666;\n    transition:.3s;\n}\n\n.dot.on{\n    background:#4CAF50;\n    box-shadow:0 0 6px #4CAF50;\n    animation:blink 1.5s infinite;\n}\n\n@keyframes blink{\n    50%{opacity:.4;}\n}\n\n.icon{\n    text-align:center;\n    font-size:30px;\n    color:#888;\n    transition:.3s;\n}\n\n.smart-room.active .icon{\n    color:#4CAF50;\n    transform:scale(1.05);\n}\n\n.status{\n    text-align:center;\n    font-size:9px;\n    letter-spacing:1px;\n    color:#bbb;\n}\n\n.smart-room.active .status{\n    color:#a5d6a7;\n}\n\n.smart-room:active::after{\n    content:'';\n    position:absolute;\n    top:50%;\n    left:50%;\n    width:0;\n    height:0;\n    border-radius:50%;\n    background:rgba(255,255,255,.3);\n    transform:translate(-50%,-50%);\n    animation:ripple .6s ease-out;\n}\n\n@keyframes ripple{\n    to{\n        width:120px;\n        height:120px;\n        opacity:0;\n    }\n}\n\n</style>\n</head>\n\n<body>\n\n<div id=\"btn\" class=\"smart-room\" onclick=\"toggle()\">\n\n    <div class=\"header\">\n        <span>Botão {{req.params.id}}</span>\n        <div id=\"dot\" class=\"dot\"></div>\n    </div>\n\n    <div id=\"icon\" class=\"icon\">\n        <i class=\"mdi mdi-lightbulb-outline\"></i>\n    </div>\n\n    <div id=\"st\" class=\"status\">OFF</div>\n\n</div>\n\n<script>\n\nconst id = {{req.params.id}};\nconst btn = document.getElementById(\"btn\");\nconst st  = document.getElementById(\"st\");\nconst dot = document.getElementById(\"dot\");\nconst icon = document.getElementById(\"icon\");\n\nfunction aplicar(s){\n\n    if(s === \"ON\"){\n        btn.classList.add(\"active\");\n        dot.classList.add(\"on\");\n        icon.innerHTML='<i class=\"mdi mdi-lightbulb-on\"></i>';\n    }else{\n        btn.classList.remove(\"active\");\n        dot.classList.remove(\"on\");\n        icon.innerHTML='<i class=\"mdi mdi-lightbulb-outline\"></i>';\n    }\n\n    st.innerText = s;\n}\n\nfunction toggle(){\n\n    const atual = st.innerText;\n    aplicar(atual===\"ON\"?\"OFF\":\"ON\");\n\n    fetch(\"/toggle\",{\n        method:\"POST\",\n        headers:{'Content-Type':'application/json'},\n        body:JSON.stringify({id:id})\n    }).catch(()=>aplicar(atual));\n}\n\nsetInterval(()=>{\n    fetch(\"/estado\")\n    .then(r=>r.json())\n    .then(d=>aplicar(d[id]||\"OFF\"));\n},700);\n\n</script>\n\n</body>\n</html>",
