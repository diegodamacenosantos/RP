        "template": "<!DOCTYPE html>\n<html lang=\"pt-br\">\n\n<head>\n    <meta charset=\"utf-8\">\n    <title>Painel Neon</title>\n\n    <style>\n        body {\n            background: #0a0a0c;\n            font-family: 'Segoe UI', Roboto, sans-serif;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            min-height: 100vh;\n            margin: 0;\n            color: white;\n        }\n\n        .header {\n            width: 100%;\n            max-width: 900px;\n            display: flex;\n            align-items: center;\n            gap: 15px;\n            padding: 15px 20px;\n            margin-top: 20px;\n\n            background: #111116;\n            border-radius: 15px;\n\n            box-shadow: 0 0 15px rgba(0, 255, 255, 0.25);\n        }\n\n        .logo {\n            height: 50px;\n        }\n\n        .titulo {\n            font-size: 22px;\n            font-weight: 600;\n            letter-spacing: 1px;\n        }\n\n        .grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));\n            gap: 25px;\n            padding: 20px;\n            width: 90%;\n            max-width: 800px;\n        }\n\n        iframe {\n            border: none;\n            width: 100%;\n            height: 130px;\n            border-radius: 15px;\n            box-shadow: 0 0 10px rgba(0, 255, 255, 0.3);\n            transition: all 0.3s ease;\n            background: #1a1a1e;\n            overflow: hidden;\n        }\n\n        iframe:hover {\n            transform: scale(1.05) translateY(-5px);\n            box-shadow: 0 0 20px rgba(0, 255, 255, 0.7);\n            cursor: pointer;\n        }\n    </style>\n</head>\n\n<body>\n\n    <div class=\"header\">\n        <!-- TROQUE AQUI PELO SEU LOGO -->\n        <img src=\"/logo.png\" class=\"logo\">\n\n        <div class=\"titulo\">\n            Sua Empresa aqui!\n        </div>\n    </div>\n\n    <div class='gri